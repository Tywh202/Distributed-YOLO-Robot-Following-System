<launch>
    <!-- Spark bringup -->
    <arg name="camera_type_tel" default="astrapro" />

    <include file="/home/spark/spark_noetic/src/spark/spark_bringup/launch/1902_bringup.launch">
        <arg name="camera_type_tel" value="$(arg camera_type_tel)" />
    </include>

    <!-- TCP bridge -->
    <node pkg="yolo_tracking"
          type="yolo_detection_bridge_node.py"
          name="yolo_detection_bridge_node"
          output="screen">
        <param name="host" value="0.0.0.0" />
        <param name="port" value="5005" />
        <param name="det_topic" value="/yolo_detection" />
    </node>

    <!-- YOLO follower -->
    <node pkg="yolo_tracking"
          type="yolo_node_release.py"
          name="yolo_follower_node"
          output="screen">

        <param name="det_topic" value="/yolo_detection" />
        <param name="depth_topic" value="/camera/depth/image_raw" />
        <param name="camera_info_topic" value="/camera/rgb/camera_info" />
        <param name="cmd_vel_topic" value="/cmd_vel" />

        <param name="target_class_topic" value="/target_class_cmd" />

        <param name="source_frame" value="camera_rgb_optical_frame" />
        <param name="target_frame" value="base_link" />

        <param name="target_class" value="person" />
        <param name="use_detection_class_directly" value="true" />

        <param name="desired_distance" value="0.8" />
        <param name="distance_threshold" value="0.12" />
        <param name="align_threshold" value="0.15" />

        <param name="linear_kp" value="0.45" />
        <param name="angular_kp" value="1.2" />

        <param name="max_linear_speed" value="0.15" />
        <param name="max_angular_speed" value="0.45" />
        <param name="search_angular_speed" value="0.18" />

        <param name="max_lost_frames" value="10" />
        <param name="depth_roi_radius" value="8" />

        <param name="min_valid_depth" value="0.15" />
        <param name="max_valid_depth" value="5.0" />

        <param name="position_filter_alpha" value="0.45" />
        <param name="velocity_filter_beta" value="0.35" />

        <param name="allow_backward" value="false" />
        <param name="control_rate_hz" value="15.0" />
        <param name="detection_timeout" value="0.8" />
        <param name="enable_search_rotation" value="true" />
    </node>
</launch>
